<Window x:Class="TowerDefenseGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tower Defense" Height="540" Width="1020"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="800"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Spielfeld Canvas: 800 x 480, 20x12 Zellen à 40px -->
        <Canvas x:Name="GameCanvas" Grid.Column="0"
                Width="800" Height="480" Background="#3a6b35"
                MouseLeftButtonDown="GameCanvas_MouseLeftButtonDown"
                MouseMove="GameCanvas_MouseMove"/>

        <!-- Seitenleiste -->
        <StackPanel Grid.Column="1" Background="#1a1a2e">

            <TextBlock Text="TOWER DEFENSE" Foreground="White" FontSize="15"
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,14,0,10"/>

            <Separator Background="#444"/>

            <!-- WP13: Diese Labels werden im Code befüllt -->
            <TextBlock x:Name="TxtLives" Foreground="#ff6b6b"
                       Margin="10,10,10,2" FontSize="13" FontWeight="Bold"/>
            <TextBlock x:Name="TxtScore" Foreground="#ffd700"
                       Margin="10,2,10,2"  FontSize="13" FontWeight="Bold"/>
            <TextBlock x:Name="TxtWave"  Foreground="#74c0fc"
                       Margin="10,2,10,8"  FontSize="13" FontWeight="Bold"/>

            <Separator Background="#444"/>

            <TextBlock Text="Turm auswählen:" Foreground="#aaaaaa"
                       Margin="10,10,10,4" FontSize="11"/>

            <RadioButton x:Name="RbBasic"       GroupName="TowerType"
                         Foreground="White" Margin="10,3,10,0" FontSize="12"
                         Content="⬛  Basic  (R=120 | D=20 | 1/s)" Checked="RbBasic_Checked"/>
            <RadioButton x:Name="RbSniper"      GroupName="TowerType"
                         Foreground="White" Margin="10,3,10,0" FontSize="12"
                         Content="🟩  Sniper  (R=250 | D=15 | 0.5/s)" Checked="RbSniper_Checked"/>
            <RadioButton x:Name="RbMachineGun"  GroupName="TowerType"
                         Foreground="White" Margin="10,3,10,10" FontSize="12"
                         Content="🟥  MG      (R=100 | D=40 | 4/s)" Checked="RbMachineGun_Checked"/>

            <TextBlock Name="TxtTowerRange" Text="Reichweite:     - px" Foreground="White" Margin="15,0,0,0"/>
            <TextBlock Name="TxtTowerDamage" Text="Schaden:        -" Foreground="White" Margin="15,0,0,0"/>
            <TextBlock Name="TxtTowerFireRate" Text="Schussrate:     - / s" Foreground="White" Margin="15,0,0,0"/>

            <Separator Background="#444"/>

            <Button x:Name="BtnNextWave" Content="▶  Nächste Welle"
                    Margin="10,12,10,6" Padding="6,4"
                    FontSize="12" Click="BtnNextWave_Click"/>

            <Button x:Name="BtnRestart" Content="↺  Neustart"
                    Margin="10,0,10,0" Padding="6,4"
                    FontSize="12" Click="BtnRestart_Click"/>

            <Separator Background="#444" Margin="0,12,0,8"/>

            <!-- WP20: Speichern / Laden -->
            <TextBlock Text="Spielstand:" Foreground="#aaaaaa"
                       Margin="10,0,10,4" FontSize="11"/>
            <Button x:Name="BtnSave" Content="💾  Speichern"
                    Margin="10,0,10,6" Padding="6,4"
                    FontSize="12" Click="BtnSave_Click"/>
            <Button x:Name="BtnLoad" Content="📂  Laden"
                    Margin="10,0,10,0" Padding="6,4"
                    FontSize="12" Click="BtnLoad_Click"/>

            <Separator Background="#444" Margin="0,12,0,8"/>

            <TextBlock Text="Tipp:" Foreground="#888" Margin="10,0,10,2" FontSize="10"/>
            <TextBlock TextWrapping="Wrap" Foreground="#666"
                       Margin="10,0,10,0" FontSize="10"
                       Text="Klicke auf den Canvas um einen Turm zu platzieren. Türme können nicht auf dem Pfad gebaut werden."/>
        </StackPanel>
    </Grid>
</Window>
